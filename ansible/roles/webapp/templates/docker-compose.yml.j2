# Managed by Ansible - do not edit manually
services:
  database:
    image: postgres:18.4
    environment:
      - POSTGRES_USER=postgres
      - POSTGRES_DB=postgres
      # Only takes effect when the data volume is first initialized (initdb
      # bakes it into the cluster); changing it later requires an ALTER USER
      # inside the running container, not just a redeploy.
      - POSTGRES_PASSWORD={{ webapp_database_superuser_password }}
    volumes:
      - pgdata:/var/lib/postgresql
      - ./01-init.sql:/docker-entrypoint-initdb.d/01-init.sql:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 3s
      timeout: 5s
      retries: 10
    restart: unless-stopped
    logging:
      driver: journald
      options:
        tag: "{% raw %}docker/{{.Name}}{% endraw %}"

  flyway:
    image: ghcr.io/r4-reach/wnc-supply-sites/flyway:latest
    # Migrate as the app user so every object is owned by {{ webapp_database_user }}
    # by default (no per-object "alter ... owner to" needed). Connection details
    # are passed via FLYWAY_* env vars rather than on the command line so the
    # password does not show up in `docker inspect` / the process list.
    environment:
      - FLYWAY_URL=jdbc:postgresql://database:5432/{{ webapp_database_name }}
      - FLYWAY_USER={{ webapp_database_user }}
      - FLYWAY_PASSWORD={{ webapp_database_password }}
    command: >
      -locations=filesystem:/flyway/sql
      -connectRetries=60
      -baselineOnMigrate=true
      -validateMigrationNaming=true
      repair migrate
    depends_on:
      database:
        condition: service_healthy
    logging:
      driver: journald
      options:
        tag: "{% raw %}docker/{{.Name}}{% endraw %}"

  webapp:
    image: ghcr.io/r4-reach/wnc-supply-sites/webapp:latest
    ports:
      - "127.0.0.1:8080:8080"
    depends_on:
      flyway:
        condition: service_completed_successfully
    environment:
      - DB_URL=database:5432
      - DB_NAME={{ webapp_database_name }}
      - DB_USER={{ webapp_database_user }}
      - DB_PASS={{ webapp_database_password }}
      - ENABLE_DISTANCE_CALCULATOR=false
      - GOOGLE_API_KEY=xxx
      - TWILIO_FROM_NUMBER=+11111111111
      - TWILIO_ACCOUNT_SID=xxxx
      - TWILIO_AUTH_TOKEN=xxxx
      - TWILIO_SMS_ENABLED=false
      - WEBSITE_URI=https://wnc-supply-sites.com
    healthcheck:
      # Spring Boot + Hikari fail-fast means Tomcat only binds 8080 once the datasource
      # is up, so "listening on 8080" is a true readiness signal. Uses bash's /dev/tcp
      # (the zulu image has bash but no curl/nc/wget), so no extra dependencies.
      test: ["CMD", "bash", "-c", "</dev/tcp/localhost/8080"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 60s
    restart: always
    logging:
      driver: journald
      options:
        tag: "{% raw %}docker/{{.Name}}{% endraw %}"

volumes:
  pgdata:
